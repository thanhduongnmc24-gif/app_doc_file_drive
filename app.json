{
  "expo": {
    "name": "Drive Reader",
    "slug": "drive-reader",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "backgroundColor": "#ffffff",
    "splash": {
      "backgroundColor": "#ffffff"
    },
    "android": {
      "package": "com.teotuyetvoi.drivereader"
    },
    "plugins": [
      [
        "expo-build-properties",
        {
          "android": {
            "enableProguardInReleaseBuilds": true
          }
        }
      ]
    ]
  }
}